{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/login.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-card">

        <div class="logo-wrap">
            <img src="{{ asset('images/logo.png') }}" alt="AniRecap logo" class="logo-img">
        </div>

        <h1 class="brand-title">AniRecap</h1>
        <p class="brand-subtitle">Connectez-vous à votre espace</p>

        {% if error %}
            <div class="flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form class="login-form" method="post">

            <div class="form-group">
                <label for="inputEmail">Email</label>
                <div class="input-icon">
                    <i class="fa-regular fa-envelope"></i>
                    <input
                        type="email"
                        value="{{ last_username }}"
                        name="email"
                        id="inputEmail"
                        autocomplete="email"
                        required
                        autofocus
                        placeholder="Entrer votre email"
                    >
                </div>
            </div>

            <div class="form-group">
                <label for="inputPassword">Password</label>
                <div class="input-icon">
                    <i class="fa-solid fa-lock"></i>
                    <input
                        type="password"
                        name="password"
                        id="inputPassword"
                        autocomplete="current-password"
                        required
                        placeholder="Creer votre mots de passe"
                    >
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="submit-btn">
                Se connecter <i class="fa-solid fa-arrow-right"></i>
            </button>
        </form>

        <p class="login-link">
            <a href="{{ path('app_register') }}">Nouvel utilisateur ?</a>
        </p>
    </div>
</div>
{% endblock %}